# ─── Database (Neon recommended; any Postgres 14+ works) ───
# Use the POOLED endpoint for the app runtime (handles many concurrent
# requests under Vercel functions). The direct endpoint (no -pooler) is
# fine for migrations and one-off scripts.
DATABASE_URL="postgresql://USER:PASS@ep-XXX-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# ─── NextAuth ───
# In production this is your deployed URL, e.g. https://observatory-admin.vercel.app
NEXTAUTH_URL="http://localhost:3001"
# openssl rand -base64 32
NEXTAUTH_SECRET="dev-secret-replace-with-openssl-rand-base64-32"

# ─── Resend (magic-link email) ───
# Leave empty in dev; the dev login backdoor at /api/dev/login bypasses email.
# In production: create an API key at https://resend.com + verify your sender domain.
RESEND_API_KEY=""
EMAIL_FROM="ACE Observatory <no-reply@observatory.example>"
EMAIL_REPLY_TO="ace-team@oas.example"

# ─── Supabase Storage (PDF uploads for agreements) ───
# Optional in dev — the admin UI hides upload affordances if these are unset.
# Required in production.
SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="agreements"

# ─── Cron secret (Vercel cron) ───
# Generated by Vercel; checked at request time in /api/cron/* routes.
CRON_SECRET=""
