      "Bash(grep -rn 'fetch\\(\"/\\\\|fetch\\(`/\\\\|countries\\\\.geo\\\\.json\\\\|us-states\\\\.geo\\\\.json' app components)",
      "Bash(grep -oE 'value=\"[0-9]{2,4}\"|>[0-9]{2,4}<' out/index.html)"
    ]
  }
}
